{
 "cells": [
  {
   "metadata": {},
   "cell_type": "raw",
   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# DeepSearchQA Notebook Version of `app.py`\\n\",\n",
    "    \"\\n\",\n",
    "    \"This notebook converts the Streamlit workflow into a step-by-step notebook flow.\\n\",\n",
    "    \"\\n\",\n",
    "    \"It keeps the same core sections:\\n\",\n",
    "    \"1. Setup and environment loading\\n\",\n",
    "    \"2. Dataset loading and random History question sampling\\n\",\n",
    "    \"3. Question selection\\n\",\n",
    "    \"4. Agent execution\\n\",\n",
    "    \"5. Response analysis (metrics, queries, sources, plan)\\n\",\n",
    "    \"6. Ground truth comparison and lightweight feedback\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 1) Setup paths, `.env`, and Python imports\\n\",\n",
    "    \"\\n\",\n",
    "    \"This section replaces Streamlit startup logic. It finds the repo root, loads `.env`, and makes `aieng-eval-agents` importable from the notebook.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"import os\\n\",\n",
    "    \"import sys\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"from dotenv import load_dotenv\\n\",\n",
    "    \"from rich.console import Console\\n\",\n",
    "    \"from rich.table import Table\\n\",\n",
    "    \"\\n\",\n",
    "    \"console = Console()\\n\",\n",
    "    \"\\n\",\n",
    "    \"def find_repo_root(start: Path) -> Path:\\n\",\n",
    "    \"    for candidate in [start, *start.parents]:\\n\",\n",
    "    \"        if (candidate / \\\"aieng-eval-agents\\\").exists() and (candidate / \\\"implementations\\\").exists():\\n\",\n",
    "    \"            return candidate\\n\",\n",
    "    \"    raise FileNotFoundError(\\\"Could not find repo root containing 'aieng-eval-agents' and 'implementations'.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"REPO_ROOT = find_repo_root(Path.cwd())\\n\",\n",
    "    \"NOTEBOOK_DIR = REPO_ROOT / \\\"implementations\\\" / \\\"tr_knowledge_qa\\\"\\n\",\n",
    "    \"ENV_PATH = REPO_ROOT / \\\".env\\\"\\n\",\n",
    "    \"AIENG_PATH = REPO_ROOT / \\\"aieng-eval-agents\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"if str(AIENG_PATH) not in sys.path:\\n\",\n",
    "    \"    sys.path.insert(0, str(AIENG_PATH))\\n\",\n",
    "    \"\\n\",\n",
    "    \"if ENV_PATH.exists():\\n\",\n",
    "    \"    load_dotenv(ENV_PATH)\\n\",\n",
    "    \"    print(f\\\"Loaded .env from: {ENV_PATH}\\\")\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    print(f\\\"No .env found at: {ENV_PATH}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Repo root: {REPO_ROOT}\\\")\\n\",\n",
    "    \"print(f\\\"Notebook data dir: {NOTEBOOK_DIR / 'data'}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 2) Import the Knowledge QA components\\n\",\n",
    "    \"\\n\",\n",
    "    \"This section mirrors the `try/except ImportError` part in Streamlit and fails early with clear setup guidance if dependencies are missing.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"try:\\n\",\n",
    "    \"    from aieng.agent_evals.knowledge_qa import KnowledgeGroundedAgent\\n\",\n",
    "    \"    from aieng.agent_evals.knowledge_qa.notebook import run_with_display, display_response\\n\",\n",
    "    \"    AGENT_AVAILABLE = True\\n\",\n",
    "    \"    print(\\\"Knowledge QA imports loaded.\\\")\\n\",\n",
    "    \"except ImportError as exc:\\n\",\n",
    "    \"    AGENT_AVAILABLE = False\\n\",\n",
    "    \"    raise ImportError(\\n\",\n",
    "    \"        \\\"Missing dependencies. Install from repo root with: \\\\n\\\"\\n\",\n",
    "    \"        \\\"  pip install -e aieng-eval-agents\\\\n\\\"\\n\",\n",
    "    \"        \\\"or run your project setup (for example: uv sync).\\\\n\\\"\\n\",\n",
    "    \"        f\\\"Original error: {exc}\\\"\\n\",\n",
    "    \"    )\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 3) Load and sample History questions\\n\",\n",
    "    \"\\n\",\n",
    "    \"This is the notebook equivalent of `load_history_questions()` in the app:\\n\",\n",
    "    \"- reads `data/DSQA-full.csv`\\n\",\n",
    "    \"- removes rows with missing answers\\n\",\n",
    "    \"- filters `problem_category == 'History'`\\n\",\n",
    "    \"- samples 5 rows\\n\",\n",
    "    \"- returns a list of display-friendly dictionaries\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"def load_history_questions(sample_size: int = 5, seed: int | None = None) -> list[dict]:\\n\",\n",
    "    \"    csv_path = NOTEBOOK_DIR / \\\"data\\\" / \\\"DSQA-full.csv\\\"\\n\",\n",
    "    \"    if not csv_path.exists():\\n\",\n",
    "    \"        raise FileNotFoundError(\\n\",\n",
    "    \"            f\\\"Dataset file not found: {csv_path}. Place DSQA-full.csv under implementations/tr_knowledge_qa/data/.\\\"\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    df = pd.read_csv(csv_path)\\n\",\n",
    "    \"    df = df.dropna(subset=[\\\"answer\\\"])\\n\",\n",
    "    \"    history_df = df[df[\\\"problem_category\\\"] == \\\"History\\\"].copy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if history_df.empty:\\n\",\n",
    "    \"        raise ValueError(\\\"No History rows found in dataset.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if len(history_df) > sample_size:\\n\",\n",
    "    \"        random_state = seed if seed is not None else random.randint(0, 10000)\\n\",\n",
    "    \"        history_df = history_df.sample(n=sample_size, random_state=random_state)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    icons = [\\\"[H1]\\\", \\\"[H2]\\\", \\\"[H3]\\\", \\\"[H4]\\\", \\\"[H5]\\\"]\\n\",\n",
    "    \"    questions = []\\n\",\n",
    "    \"    for idx, (_, row) in enumerate(history_df.iterrows()):\\n\",\n",
    "    \"        questions.append(\\n\",\n",
    "    \"            {\\n\",\n",
    "    \"                \\\"icon\\\": icons[idx % len(icons)],\\n\",\n",
    "    \"                \\\"title\\\": f\\\"History Question {idx + 1}\\\",\\n\",\n",
    "    \"                \\\"question\\\": str(row[\\\"problem\\\"]),\\n\",\n",
    "    \"                \\\"example_id\\\": row[\\\"example_id\\\"],\\n\",\n",
    "    \"                \\\"answer\\\": str(row[\\\"answer\\\"]),\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return questions\\n\",\n",
    "    \"\\n\",\n",
    "    \"history_questions = load_history_questions(sample_size=5)\\n\",\n",
    "    \"print(f\\\"Loaded {len(history_questions)} History questions.\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4) Preview candidate questions\\n\",\n",
    "    \"\\n\",\n",
    "    \"This section replaces clickable Streamlit tiles with a compact table so you can pick an index.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"table = Table(title=\\\"Sample History Questions\\\")\\n\",\n",
    "    \"table.add_column(\\\"Index\\\", justify=\\\"right\\\")\\n\",\n",
    "    \"table.add_column(\\\"Title\\\")\\n\",\n",
    "    \"table.add_column(\\\"Example ID\\\")\\n\",\n",
    "    \"table.add_column(\\\"Question (truncated)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"for i, item in enumerate(history_questions):\\n\",\n",
    "    \"    q = item[\\\"question\\\"].strip().replace(\\\"\\\\n\\\", \\\" \\\")\\n\",\n",
    "    \"    q_short = (q[:120] + \\\"...\\\") if len(q) > 120 else q\\n\",\n",
    "    \"    table.add_row(str(i), item[\\\"title\\\"], str(item[\\\"example_id\\\"]), q_short)\\n\",\n",
    "    \"\\n\",\n",
    "    \"console.print(table)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 5) Select one question to process\\n\",\n",
    "    \"\\n\",\n",
    "    \"In Streamlit, selection is stored in `st.session_state`. In the notebook, you can choose by index and store it in a Python variable.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"SELECTED_INDEX = 0  # Change this to 0..4\\n\",\n",
    "    \"\\n\",\n",
    "    \"if not (0 <= SELECTED_INDEX < len(history_questions)):\\n\",\n",
    "    \"    raise IndexError(f\\\"SELECTED_INDEX must be between 0 and {len(history_questions) - 1}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"selected_question = history_questions[SELECTED_INDEX]\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Selected question:\\\")\\n\",\n",
    "    \"print(f\\\"- Title: {selected_question['title']}\\\")\\n\",\n",
    "    \"print(f\\\"- Example ID: {selected_question['example_id']}\\\")\\n\",\n",
    "    \"print(f\\\"- Question: {selected_question['question']}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 6) Run the agent\\n\",\n",
    "    \"\\n\",\n",
    "    \"This section is the notebook replacement for the \\\"Process with Agent\\\" button.\\n\",\n",
    "    \"\\n\",\n",
    "    \"Use `await run_with_display(...)` to get live plan/tool-call updates in Jupyter while the agent runs.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"if not AGENT_AVAILABLE:\\n\",\n",
    "    \"    raise RuntimeError(\\\"Agent is not available due to import/setup issues.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"agent = KnowledgeGroundedAgent(enable_planning=True)\\n\",\n",
    "    \"response = await run_with_display(agent, selected_question[\\\"question\\\"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Agent run completed.\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 7) Display final answer and execution metrics\\n\",\n",
    "    \"\\n\",\n",
    "    \"This section mirrors the answer + metrics cards in Streamlit, but as notebook output.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"duration_sec = response.total_duration_ms / 1000\\n\",\n",
    "    \"subtitle = f\\\"Duration: {duration_sec:.2f}s | Sources: {len(response.sources)} | Queries: {len(response.search_queries)}\\\"\\n\",\n",
    "    \"display_response(console, response.text, title=\\\"Agent Answer\\\", subtitle=subtitle)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Total duration (s): {duration_sec:.2f}\\\")\\n\",\n",
    "    \"print(f\\\"Sources found: {len(response.sources)}\\\")\\n\",\n",
    "    \"print(f\\\"Search queries: {len(response.search_queries)}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 8) Inspect search queries, sources, and research plan\\n\",\n",
    "    \"\\n\",\n",
    "    \"This section corresponds to the Streamlit expanders and helps with debugging and evaluation.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(\\\"SEARCH QUERIES\\\")\\n\",\n",
    "    \"if response.search_queries:\\n\",\n",
    "    \"    for i, query in enumerate(response.search_queries, 1):\\n\",\n",
    "    \"        print(f\\\"{i}. {query}\\\")\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    print(\\\"(none)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\nSOURCES\\\")\\n\",\n",
    "    \"if response.sources:\\n\",\n",
    "    \"    for i, src in enumerate(response.sources, 1):\\n\",\n",
    "    \"        title = getattr(src, \\\"title\\\", \\\"(untitled)\\\")\\n\",\n",
    "    \"        url = getattr(src, \\\"url\\\", \\\"\\\")\\n\",\n",
    "    \"        snippet = getattr(src, \\\"snippet\\\", \\\"\\\")\\n\",\n",
    "    \"        print(f\\\"{i}. {title} -> {url}\\\")\\n\",\n",
    "    \"        if snippet:\\n\",\n",
    "    \"            print(f\\\"   snippet: {snippet[:200]}{'...' if len(snippet) > 200 else ''}\\\")\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    print(\\\"(none)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\nRESEARCH PLAN\\\")\\n\",\n",
    "    \"if response.plan and response.plan.steps:\\n\",\n",
    "    \"    print(f\\\"Reasoning: {response.plan.reasoning}\\\")\\n\",\n",
    "    \"    status_icon = {\\n\",\n",
    "    \"        \\\"completed\\\": \\\"[done]\\\",\\n\",\n",
    "    \"        \\\"in_progress\\\": \\\"[doing]\\\",\\n\",\n",
    "    \"        \\\"pending\\\": \\\"[todo]\\\",\\n\",\n",
    "    \"        \\\"skipped\\\": \\\"[skip]\\\",\\n\",\n",
    "    \"        \\\"failed\\\": \\\"[fail]\\\",\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"    for step in response.plan.steps:\\n\",\n",
    "    \"        icon = status_icon.get(str(step.status), \\\"[?]\\\")\\n\",\n",
    "    \"        print(f\\\"{icon} Step {step.step_id}: {step.description} (Tool: {step.suggested_tool})\\\")\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    print(\\\"(no plan available)\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 9) Ground truth comparison\\n\",\n",
    "    \"\\n\",\n",
    "    \"This section mirrors the side-by-side comparison in the app so you can quickly inspect answer quality.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(\\\"GROUND TRUTH ANSWER:\\\")\\n\",\n",
    "    \"print(selected_question[\\\"answer\\\"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\nAGENT ANSWER:\\\")\\n\",\n",
    "    \"print(response.text[:800] + (\\\"...\\\" if len(response.text) > 800 else \\\"\\\"))\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 10) Optional feedback capture\\n\",\n",
    "    \"\\n\",\n",
    "    \"This section is a notebook alternative to the thumbs up/down form.\\n\",\n",
    "    \"It stores feedback in a local dictionary that you can later send to Langfuse if needed.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Set manually: 1 for thumbs up, 0 for thumbs down\\n\",\n",
    "    \"feedback_score = 1\\n\",\n",
    "    \"feedback_label = \\\"thumbs up\\\" if feedback_score == 1 else \\\"thumbs down\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"feedback_record = {\\n\",\n",
    "    \"    \\\"example_id\\\": selected_question[\\\"example_id\\\"],\\n\",\n",
    "    \"    \\\"question\\\": selected_question[\\\"question\\\"],\\n\",\n",
    "    \"    \\\"feedback_score\\\": feedback_score,\\n\",\n",
    "    \"    \\\"feedback_label\\\": feedback_label,\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Feedback captured:\\\")\\n\",\n",
    "    \"print(feedback_record)\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
    " \"metadata\": {\n",
    "  \"kernelspec\": {\n",
    "   \"display_name\": \"Python 3\",\n",
    "   \"language\": \"python\",\n",
    "   \"name\": \"python3\"\n",
    "  },\n",
